{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && npx tsx scripts/prepare-deploy-db.ts && next build",
    "prepare:deploy-db": "npx tsx scripts/prepare-deploy-db.ts",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "dotenv -e .env.example -- prisma db push",
    "db:seed": "dotenv -e .env.example -e .env -- prisma db seed",
    "db:setup": "npm run db:generate && npm run db:push && npm run db:seed",
    "admin:reset": "dotenv -e .env.example -e .env -- npx tsx scripts/reset-admin.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.8.1",
    "@prisma/adapter-libsql": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.42.2",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "next": "16.2.10",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
