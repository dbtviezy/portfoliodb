# Local SQLite (dev). On Vercel/serverless, file: SQLite will NOT work —
# use Turso (recommended) or a host with a persistent disk.
DATABASE_URL="file:./dev.db"

# Required in production — long random string (session cookies).
JWT_SECRET=change-this-secret-in-production

# Used by prisma seed / scripts/reset-admin.ts, and by first-login bootstrap
# when the Admin table is empty (credentials must match exactly).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Production on Vercel (or any serverless host): Turso / libSQL
# Create a DB at https://turso.tech, then set both:
# TURSO_DATABASE_URL="libsql://your-db-name-org.turso.io"
# TURSO_AUTH_TOKEN="your-turso-token"
# You can also put the libsql:// URL in DATABASE_URL instead of TURSO_DATABASE_URL.

# Studio photo uploads (drag-and-drop). On Vercel:
# Project ? Storage ? Create Blob Store ? token is added as BLOB_READ_WRITE_TOKEN
# Locally without Blob: files go to public/uploads/
# BLOB_READ_WRITE_TOKEN=

# Optional: better EN?RU translation in Studio (Save & translate).
# Without this, free Google translate is used automatically.
# OPENAI_API_KEY=
# OPENAI_TRANSLATE_MODEL=gpt-4o-mini

# Optional canonical site URL (OG / sitemap)
# NEXT_PUBLIC_SITE_URL=https://portfoliodb-three.vercel.app
