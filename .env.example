# Local SQLite (dev only). For Vercel/production use a durable DB URL
# (Turso/libSQL, Postgres, etc.) — file:./dev.db will NOT work on serverless.
DATABASE_URL="file:./dev.db"

# Required in production — use a long random string
JWT_SECRET=change-this-secret-in-production

# Used by prisma seed / scripts/reset-admin.ts (set in host env for prod seed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

