generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Portfolio {
  id               Int      @id @default(autoincrement())
  lang             String   @default("en")
  heroLocation     String   @default("")
  heroText1        String   @default("")
  heroText2        String   @default("")
  heroDesc         String   @default("")
  heroBtn          String   @default("Work")
  aboutTitle       String   @default("About")
  aboutDesc1       String   @default("")
  aboutDesc2       String   @default("")
  aboutExpertise   String   @default("")
  profileImage     String   @default("")
  aboutStats1Label String   @default("")
  aboutStats1Value String   @default("")
  aboutStats2Label String   @default("")
  aboutStats2Value String   @default("")
  aboutStats3Label String   @default("")
  aboutStats3Value String   @default("")
  contactSubtitle  String   @default("")
  contactTitle1    String   @default("")
  contactTitle2    String   @default("")
  contactBtn       String   @default("Write")
  contactEmail     String   @default("")
  contactTelegram  String   @default("")
  contactBehance   String   @default("")
  contactDribbble  String   @default("")
  contactInstagram String   @default("")
  contactChannels  String   @default("[]")
  navbarProjects   String   @default("Projects")
  navbarContact    String   @default("Contact")
  skillsTitle      String   @default("Skills")
  projectsTitle    String   @default("Work")
  projectsShowing  String   @default("Showing")
  projectsOf       String   @default("of")
  projectsViewAll  String   @default("View all")
  projectsAllTitle String   @default("All work")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([lang])
}

model Skill {
  id        Int      @id @default(autoincrement())
  lang      String   @default("en")
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExpertiseItem {
  id        Int      @id @default(autoincrement())
  lang      String   @default("en")
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  category    String
  year        String
  description String
  detail      String   @default("")
  image       String
  images      String   @default("[]")
  imageFrame  String   @default("{\"zoom\":1,\"x\":50,\"y\":50}")
  video       String   @default("")
  links       String   @default("[]")
  featured    Boolean  @default(false)
  completed   Boolean  @default(true)
  order       Int      @default(0)
  lang        String   @default("en")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([featured])
  @@index([lang])
}
